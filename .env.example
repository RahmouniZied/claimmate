# Copy to .env and fill in. Get a key from Google AI Studio.
GOOGLE_API_KEY=your_key_here
GOOGLE_GENAI_USE_VERTEXAI=0

# Optional: override models if newer ones are available.
# CLAIMMATE_FLASH_MODEL=gemini-2.5-flash
# CLAIMMATE_PRO_MODEL=gemini-2.5-pro

# Optional: delegate to the Clause-Finder over A2A instead of in-process.
# CLAIMMATE_CLAUSE_FINDER_URL=http://localhost:8001
