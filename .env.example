# Copy to .env and fill in. Get a key from Google AI Studio.
GOOGLE_API_KEY=your_key_here
GOOGLE_GENAI_USE_VERTEXAI=0

# Optional: override models. Defaults run entirely on the free tier on
# Gemini 3.1 Flash-Lite (both agents).
# CLAIMMATE_FLASH_MODEL=gemini-3.1-flash-lite
# CLAIMMATE_PRO_MODEL=gemini-3.1-flash-lite
# With billing enabled you can give the Clause-Finder a stronger model:
# CLAIMMATE_PRO_MODEL=gemini-3-pro-preview

# Optional: delegate to the Clause-Finder over A2A instead of in-process.
# CLAIMMATE_CLAUSE_FINDER_URL=http://localhost:8001
